{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Open Source Discord Alternatives Schema",
  "type": "object",
  "required": ["name", "website", "open_source", "features"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Project name"
    },
    "website": {
      "type": "string",
      "format": "uri",
      "description": "Official website or primary project page"
    },
    "repo": {
      "type": "string",
      "format": "uri",
      "description": "Source code repository (GitHub, GitLab, etc.)"
    },
    "license": {
      "type": "string",
      "description": "Open-source license (e.g. MIT, AGPL-3.0, Apache-2.0)"
    },
    "open_source": {
      "type": "boolean",
      "const": true,
      "description": "Must always be true for inclusion in this dataset"
    },

    "features": {
      "type": "object",
      "required": [
        "privacy",
        "core_chat",
        "voice_media",
        "community",
        "platform",
        "architecture",
        "adoption",
        "safety"
      ],
      "properties": {
        "privacy": {
          "type": "object",
          "properties": {
            "encryption": {
              "enum": ["none", "optional", "partial", "full", "unknown"]
            },
            "data_harvesting_risk": {
              "enum": ["low", "medium", "high", "unknown"]
            },
            "security_history": {
              "enum": ["good", "mixed", "poor", "unknown"]
            },
            "kyc_required": {
              "enum": ["none", "optional", "required", "unknown"]
            },
            "nsfw_support": {
              "enum": ["none", "limited", "full", "unknown"]
            }
          }
        },

        "core_chat": {
          "type": "object",
          "properties": {
            "channels": {
              "enum": ["none", "basic", "advanced", "unknown"]
            },
            "channel_history": {
              "enum": ["none", "limited", "full", "unknown"]
            },
            "persistent_channel_order": {
              "type": "boolean"
            },
            "threads": {
              "enum": ["none", "basic", "advanced", "unknown"]
            },
            "pinned_posts": {
              "enum": [true, false, "partial"]
            },
            "direct_messages": {
              "type": "boolean"
            },
            "dm_groups": {
              "type": "boolean"
            },
            "pings": {
              "type": "boolean"
            },
            "reactions": {
              "type": "boolean"
            },
            "embeds": {
              "type": "boolean"
            },
            "markdown": {
              "enum": ["none", "basic", "advanced", "unknown"]
            },
            "message_editing": {
              "type": "boolean"
            },
            "search": {
              "enum": ["none", "basic", "advanced", "unknown"]
            },
            "typing_indicators": {
              "type": "boolean"
            }
          }
        },

        "voice_media": {
          "type": "object",
          "properties": {
            "voice_calls": {
              "type": "boolean"
            },
            "video_calls": {
              "type": "boolean"
            },
            "screen_sharing": {
              "type": "boolean"
            },
            "stage": {
              "type": "boolean"
            },
            "voice_text_chat": {
              "type": "boolean"
            },
            "streaming": {
              "type": "boolean"
            },
            "noise_suppression": {
              "type": "boolean"
            },
            "file_sharing": {
              "enum": ["none", "limited", "full", "unknown"]
            },
            "soundboard": {
              "type": "boolean"
            },
            "activities_games": {
              "type": "boolean"
            },
            "custom_ringtones": {
              "type": "boolean"
            },
            "smart_video_loading_hls": {
              "type": "boolean"
            }
          }
        },

        "community": {
          "type": "object",
          "properties": {
            "bots_plugins": {
              "enum": ["none", "limited", "full", "unknown"]
            },
            "plural_kit_support": {
              "enum": ["none", "partial", "full", "unknown"]
            },
            "custom_emotes": {
              "type": "boolean"
            },
            "custom_stickers": {
              "type": "boolean"
            },
            "polls": {
              "enum": ["none", "basic", "advanced", "unknown"]
            },
            "events": {
              "enum": ["none", "basic", "advanced", "unknown"]
            },
            "collaboration_tools": {
              "enum": ["none", "basic", "advanced", "unknown"]
            },
            "import_from_discord": {
              "enum": ["none", "partial", "full", "unknown"]
            },
            "discord_bridge_sync": {
              "enum": ["none", "partial", "full", "unknown"]
            },
            "application_gate": {
              "type": "boolean"
            },
            "automod": {
              "enum": ["none", "basic", "advanced", "unknown"]
            }
          }
        },

        "platform": {
          "type": "object",
          "properties": {
            "mobile": {
              "type": "boolean"
            },
            "web": {
              "type": "boolean"
            },
            "desktop": {
              "type": "boolean"
            },
            "desktop_app_platform": {
              "enum": ["electron", "tauri", "qt", "flutter", "native", "none", "unknown"]
            },
            "cross_language_support": {
              "enum": ["none", "partial", "full", "unknown"]
            }
          }
        },

        "architecture": {
          "type": "object",
          "properties": {
            "federation": {
              "enum": ["none", "partial", "full", "unknown"]
            },
            "self_hosting": {
              "enum": ["none", "partial", "full", "unknown"]
            },
            "discovery": {
              "enum": ["none", "basic", "advanced", "unknown"]
            },
            "open_source": {
              "type": "boolean",
              "const": true
            }
          }
        },

        "adoption": {
          "type": "object",
          "properties": {
            "userbase": {
              "enum": ["low", "medium", "high", "unknown"]
            },
            "performance": {
              "enum": ["low", "medium", "high", "unknown"]
            },
            "market_focus": {
              "enum": [
                "gaming",
                "general",
                "enterprise",
                "privacy",
                "mixed",
                "unknown"
              ]
            },
            "consumer_relationship": {
              "enum": [
                "closed",
                "neutral",
                "open",
                "community-driven",
                "unknown"
              ]
            }
          }
        },

        "safety": {
          "type": "object",
          "properties": {
            "ai_safety": {
              "enum": ["none", "partial", "yes", "unknown"]
            },
            "safety_concerns": {
              "enum": ["low", "medium", "high", "unknown"]
            },
            "transparency": {
              "enum": ["low", "medium", "high", "unknown"]
            }
          }
        }
      }
    }
  }
}
